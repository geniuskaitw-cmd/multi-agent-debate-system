# LLM API 金鑰（必填）
GOOGLE_API_KEY=your-google-api-key-here

# 各智能體使用的模型名稱（選填，以下為預設值）
AGENT_A_MODEL=gemini-3-flash-preview
AGENT_B_MODEL=gemini-3-flash-preview
AGENT_C_MODEL=gemini-3-flash-preview
AGENT_D_MODEL=gemini-3.1-pro-preview

# LLM 呼叫設定（選填，以下為預設值）
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# JWT 認證密鑰（必填）
JWT_SECRET=your-secret-key-here
